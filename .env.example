# SmartKalk v15 environment
# Copy this file to .env and fill in values.

PORT=3000
PUBLIC_URL=http://localhost:3000

# Stripe secret key from Stripe Dashboard
# Test key starts with sk_test_
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret
# For local testing, use:
# stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxx

# Used to sign local premium tokens
# Set this to a long random value before production.
PREMIUM_TOKEN_SECRET=replace-with-long-random-secret
